# Memory Schema — Environment Variables
#
# Copy to .env and fill in your values.
# Or export directly: export VOYAGE_API_KEY=voy-xxxxx

# Voyage AI API key (required for embeddings)
# Get yours at: https://dash.voyageai.com/
VOYAGE_API_KEY=

# Neo4j connection (defaults work with docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Project identity (optional, can also use --project flag)
MEMORY_PROJECT=default
MEMORY_ROOT=.
